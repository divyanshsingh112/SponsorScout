<!-- PAGE 1: COVER & EXECUTIVE SUMMARY (Instagram) -->
<div class="page">
    <div class="page-header">
        <span class="brand">SponsorScout Proposals</span>
        <span class="page-num">01 / 05</span>
    </div>
    
    <div class="hero">
        <h1>{{channelName}}</h1>
        <p style="font-size: 14px; color: #94a3b8; margin-bottom: 5px;">@{{instagramHandle}}</p>
        <p>Exclusive Sponsorship Proposal for <span class="gradient-text" style="-webkit-text-fill-color: initial; font-weight: 800;">{{targetSponsor}}</span></p>
        
        <div class="stats-row" style="max-width: 600px;">
            <div class="stat-item">
                <div class="stat-val">{{totalFollowers}}</div>
                <div class="stat-lbl">Followers</div>
            </div>
            <div class="stat-item">
                <div class="stat-val">{{avgReelPlays}}</div>
                <div class="stat-lbl">Avg. Reels Plays</div>
            </div>
            <!-- BUG 01 FIX: Changed from "Engagement" to "Reach-to-Follower Ratio" -->
            <!-- Color: green when >100% (viral), indigo otherwise -->
            <div class="stat-item">
                {{#if hasFullEngagement}}
                <div class="stat-val" style="color: #4f46e5;">{{trueEngagementRate}}%</div>
                <div class="stat-lbl">True Engagement Rate</div>
                {{else}}
                <div class="stat-val" style="color: {{#if isViralReach}}#16a34a{{else}}#4f46e5{{/if}};">{{reachRatio}}%</div>
                <div class="stat-lbl">Reach-to-Follower Ratio</div>
                {{#if isViralReach}}
                <div style="margin-top: 4px;">
                    <span style="display: inline-block; background: #dcfce7; color: #15803d; font-size: 8px; font-weight: 700; padding: 2px 8px; border-radius: 10px; text-transform: uppercase; letter-spacing: 0.5px;">🔥 Viral Reach</span>
                </div>
                {{/if}}
                {{/if}}
            </div>
            <!-- NEW FEATURE 01: Audience Authenticity Score (4th card) -->
            <div class="stat-item" style="position: relative;">
                <div class="stat-val" style="color: {{authenticityColor}};">{{authenticityScore}}</div>
                <div class="stat-lbl">Authenticity Score</div>
                <div style="margin-top: 6px; width: 100%; height: 4px; background: #e2e8f0; border-radius: 4px; overflow: hidden;">
                    <div style="height: 100%; width: {{authenticityScore}}%; background: {{authenticityColor}}; border-radius: 4px;"></div>
                </div>
                <div style="font-size: 8px; color: {{authenticityColor}}; font-weight: 700; margin-top: 4px; text-transform: uppercase;">{{authenticityLabel}}</div>
            </div>
        </div>
        
        <div class="fee-card">
            <div class="lbl">Recommended Placement Fee</div>
            <div class="val">₹{{finalValuation}}</div>
        </div>

        <!-- Authenticity context text -->
        <div style="margin-top: 16px; font-size: 10px; color: #64748b; line-height: 1.5; max-width: 500px; text-align: center; font-style: italic;">
            {{authenticityContext}}
        </div>
    </div>
    
    <div class="page-footer">
        <span>Calibrated: {{currentDate}} — Data valid for 30 days. Re-generate after {{expiryDate}}.</span>
        <span>Target placement: {{integrationFormat}}</span>
    </div>
</div>
