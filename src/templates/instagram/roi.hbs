<!-- PAGE 3: ROI PROJECTION (Instagram) -->
<!-- BUG 05 FIX: Uses Instagram-specific benchmark ranges -->
<!-- NEW FEATURE 05: Monthly Retainer row added -->
<div class="page">
    <div class="page-header">
        <span class="brand">ROI Projection</span>
        <span class="page-num">03 / 05</span>
    </div>
    
    <div class="content-body">
        <h2 class="section-title">Campaign ROI Projections</h2>
        <p class="intro-text">
            The pricing model for this sponsorship placement is built directly upon empirical performance metrics. Below is the transparent breakdown of expected reach and value delivery.
        </p>
        
        <table class="roi-table">
            <thead>
                <tr>
                    <th>Placement Format</th>
                    <th>Reach / Base CPM</th>
                    <th>Multipliers Applied</th>
                    <th>Estimated Value</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><strong>Instagram Reel</strong></td>
                    <td>{{avgReelPlays}} avg. plays / ₹100 CPM</td>
                    <td>Geo: {{geoMultiplier}}x | Resonance: {{resonanceMultiplier}}x</td>
                    <td><strong>₹{{reelValuation}} INR</strong></td>
                </tr>
                <tr>
                    <td><strong>Instagram Story</strong></td>
                    <td>{{avgStoryViews}} avg. views / ₹200 CPM</td>
                    <td>Geo: {{geoMultiplier}}x | Resonance: {{resonanceMultiplier}}x</td>
                    <td><strong>₹{{storyValuation}} INR</strong></td>
                </tr>
                <tr>
                    <td><strong>Combined Campaign Total</strong></td>
                    <td colspan="2">Reels & Stories Integrated Synergy</td>
                    <td><strong>₹{{finalValuation}} INR</strong></td>
                </tr>
                <!-- NEW FEATURE 05: Monthly Retainer Estimate -->
                <tr style="background: #f0eeff;">
                    <td><strong>Monthly Retainer Estimate</strong></td>
                    <td colspan="2">4 posts/month ongoing partnership</td>
                    <td><strong style="color: #4f46e5;">₹{{monthlyRetainerEstimate}} INR</strong></td>
                </tr>
            </tbody>
        </table>

        <!-- YOU VS INDUSTRY BENCHMARK SECTION -->
        <!-- BUG 05 FIX: Instagram-specific ranges and label -->
        <div class="benchmark-section">
            <h3 class="benchmark-title">YOU VS. INSTAGRAM INDUSTRY BENCHMARK</h3>
            <p class="benchmark-subtitle">Where your valuation stands compared to peer Instagram creators in your niche</p>
            <div class="benchmark-bar-container">
                <span class="benchmark-low">₹{{benchmarkLow}}</span>
                <div class="benchmark-track">
                    <div class="benchmark-fill" style="width: {{benchmarkPosition}}%;"></div>
                    <div class="benchmark-marker" style="left: {{benchmarkPosition}}%;">
                        <span class="benchmark-marker-label">₹{{formattedFee}} (You)</span>
                    </div>
                </div>
                <span class="benchmark-high">₹{{benchmarkHigh}}</span>
            </div>
            <p class="benchmark-note">Calculated using SponsorScout Dynamic Niche CPM Matrix — Instagram Benchmarks</p>
        </div>

        <!-- 3-TIER PACKAGE TABLE -->
        <div class="tier-section">
            <h3 class="tier-title">Sponsorship Package Options</h3>
            <table class="tier-table">
                <thead>
                    <tr>
                        <th style="width: 20%;">Package Tier</th>
                        <th style="width: 50%;">Deliverables Included</th>
                        <th style="width: 30%;">Suggested Pricing</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><span class="tier-badge starter">Starter</span></td>
                        <td>{{deliverableStarter}}</td>
                        <td><span class="tier-price">₹{{tierStarter}} INR</span></td>
                    </tr>
                    <tr class="tier-highlighted">
                        <td><span class="tier-badge standard">Standard</span></td>
                        <td><strong>{{deliverableStandard}} (Recommended)</strong></td>
                        <td><span class="tier-price highlighted">₹{{tierStandard}} INR</span></td>
                    </tr>
                    <tr>
                        <td><span class="tier-badge premium">Premium</span></td>
                        <td>{{deliverablePremium}}</td>
                        <td><span class="tier-price">₹{{tierPremium}} INR</span></td>
                    </tr>
                </tbody>
            </table>
            <p class="tier-note">*Packages are customized based on current platform engagement and average reach projections.</p>
        </div>

        <div class="formula-box">
            Instagram Valuation Formula:<br>
            Reel = (Plays * 100 * Geo * Resonance) / 1000 | Story = (Views * 200 * Geo * Resonance) / 1000
        </div>

        <div style="font-size: 10px; color: #94a3b8; line-height: 1.5; margin-top: 30px; text-align: center; font-style: italic; border-top: 1px dashed #e2e8f0; padding-top: 15px;">
            Data self-reported by creator via Instagram Professional Dashboard. SponsorScout recommends requesting live dashboard screenshots before contract finalization.
        </div>
    </div>
    
    <div class="page-footer">
        <span>Calibrated: {{currentDate}} — Data valid for 30 days. Re-generate after {{expiryDate}}.</span>
        <span>Strict Mathematical Evaluation</span>
    </div>
</div>
